# Django
DJANGO_SETTINGS_MODULE=payroll_platform.settings.development
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000
DJANGO_TIME_ZONE=UTC
DJANGO_LOG_LEVEL=INFO

# PostgreSQL (URL-encode special characters in credentials)
POSTGRES_DB=payroll
POSTGRES_USER=payroll
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql://payroll:replace-with-a-strong-password@db:5432/payroll
DATABASE_CONN_MAX_AGE=60

# Background jobs
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db

# Production security overrides
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000

# Authentication security
ACCOUNT_LOCKOUT_THRESHOLD=5
ACCOUNT_LOCKOUT_DURATION=900
SESSION_IDLE_TIMEOUT=1800
SESSION_COOKIE_AGE=28800

# Secure document uploads
DOCUMENT_MAX_UPLOAD_BYTES=10485760

# Production secret-manager values (generate Fernet keys; first key encrypts, remaining keys decrypt during rotation)
FIELD_ENCRYPTION_KEYS=
DATA_FINGERPRINT_KEY=
RATE_LIMIT_ENABLED=false
API_RATE_LIMIT=300
AUTH_RATE_LIMIT=10
RATE_LIMIT_WINDOW_SECONDS=60
# Comma-separated jurisdictions with documented legal/accounting sign-off; leave empty to fail closed
LEGAL_REVIEW_APPROVED_JURISDICTIONS=
DATABASE_SSLMODE=require
